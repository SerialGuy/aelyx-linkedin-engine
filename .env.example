# These are set as GitHub repo secrets and variables (Settings -> Secrets and
# variables -> Actions), NOT as a real .env file committed to the repo. This
# file just documents what's needed and where each value lives.

# ---- Provider selection (repo VARIABLE, not secret -- it's not sensitive) ----
# Which AI provider generates your posts. One of: anthropic | openai | gemini
# Set this under Settings -> Secrets and variables -> Actions -> Variables tab.
LLM_PROVIDER=anthropic

# ---- API keys (repo SECRETS -- only add the one(s) you'll actually use) ----
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# ---- Optional: override the default model for whichever provider is active ----
# (repo VARIABLES -- leave unset to use the built-in defaults in llm_provider.py)
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-5.5
GEMINI_MODEL=gemini-3.5-flash

# ---- How many posts to generate per day (repo VARIABLE) ----
# Default is 1. Set to e.g. 3 for three fresh posts every run.
POSTS_PER_DAY=1

# ---- LinkedIn publishing (repo SECRETS) ----
# Required only once LinkedIn Community Management API access is approved.
# Leave unset until then -- the system queues posts for manual publishing instead.
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_URN=urn:li:organization:YOUR_ORG_ID
